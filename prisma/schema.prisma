generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VOLUNTEER
  ASSOCIATION
  ADMIN
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  MISSION_REMINDER
  NEW_VOLUNTEER_BOOKING
  NO_SHOW_REPORTED
  NEW_MISSION_AVAILABLE
}

enum MissionStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum SlotStatus {
  OPEN
  FULL
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  password         String?
  roles            Role[]   @default([VOLUNTEER])
  firstName        String?
  arrondissement   Int?
  bio              String?
  avatarUrl        String?
  reliabilityScore Float    @default(5.0)
  noShowCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  bookings         Booking[]
  ratingsGiven     Rating[]         @relation("RatingGiver")
  associations     AssociationMember[]
  notifications    Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Association {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  rnaNumber      String?  @unique
  rnaVerified    Boolean  @default(false)
  humanValidated Boolean  @default(false)
  description    String?  @db.Text
  address        String
  arrondissement Int
  lat            Float?
  lng            Float?
  logoUrl        String?
  coverUrl       String?
  website        String?
  category       String
  avgRating      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members  AssociationMember[]
  missions Mission[]

  @@map("associations")
}

model AssociationMember {
  id            String   @id @default(cuid())
  userId        String
  associationId String
  isOwner       Boolean  @default(false)
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  association Association @relation(fields: [associationId], references: [id])

  @@unique([userId, associationId])
  @@map("association_members")
}

model Mission {
  id            String        @id @default(cuid())
  associationId String
  title         String
  description   String        @db.Text
  category      String
  address       String?
  lat           Float?
  lng           Float?
  durationMin   Int
  maxVolunteers Int           @default(1)
  status        MissionStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  slots       Slot[]

  @@map("missions")
}

model Slot {
  id             String     @id @default(cuid())
  missionId      String
  startsAt       DateTime
  endsAt         DateTime
  spotsTotal     Int
  spotsRemaining Int
  status         SlotStatus @default(OPEN)
  createdAt      DateTime   @default(now())

  mission  Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("slots")
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  slotId      String
  status      BookingStatus @default(CONFIRMED)
  cancelledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  slot         Slot          @relation(fields: [slotId], references: [id])
  rating       Rating?
  noShowReport NoShowReport?

  @@unique([userId, slotId])
  @@map("bookings")
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  fromType  String
  fromId    String
  score     Int
  comment   String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  giver    User    @relation("RatingGiver", fields: [fromId], references: [id])

  @@map("ratings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model NoShowReport {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  reportedBy String
  note       String?
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("no_show_reports")
}
